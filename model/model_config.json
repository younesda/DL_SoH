{
  "project": "Battery SoH LSTM",
  "phase": "Phase 4 — Final",
  "created_at": "2026-03-22",

  "model": {
    "run_id": 16,
    "checkpoint": "best_lstm_v16.pt",
    "architecture": "BiLSTM(64, bidirectional) + AdditiveAttention -> Dropout(0.2) -> FC(32, relu) -> FC(1)",
    "n_params": 44737,
    "input_shape": [10, 13],
    "output": "SoH (%)"
  },

  "ensemble": {
    "description": "Ensemble LSTM#16 + Ridge v9 (alpha calibré sur val set)",
    "alpha_lstm": 0.05,
    "alpha_ridge": 0.95,
    "ridge_alpha_sklearn": 1.0,
    "note": "alpha=0.05 optimal sur val set (run #18 honnête) et test set (run #17) — identiques"
  },

  "features": {
    "window_size": 10,
    "n_features": 13,
    "feature_names": [
      "mean_V", "std_V", "min_V",
      "mean_T", "std_T", "mean_I",
      "slope_SoC",
      "voltage_drop", "capacity_proxy", "temp_rise", "voltage_end",
      "soh_prev",
      "soh_lin_extrap"
    ],
    "soh_prev_note": "SoH[t] pour t < last timestep, SoH[t-1] pour t = last (anti-leakage)",
    "soh_lin_extrap_note": "soh_prev[8] + slope_lineaire(soh_prev[0:9]) — projection du prochain SoH, constante sur la fenêtre",
    "aggregation": "per_cycle (20 bins/cycle, sorted SoC descending)",
    "normalization": "StandardScaler fitted on train set only"
  },

  "scaler": {
    "source": "metadata_v9.json",
    "mean": [3.455209, 0.211122, 2.959141, 35.353778, 3.572107,
             -2.377875, -5.04343, 0.953434, 47.557506, 13.334483, 2.959141,
             82.691327, 82.001769],
    "scale": [0.137981, 0.016435, 0.100888, 9.773384, 1.532175,
              0.938854, 0.041609, 0.071528, 18.777078, 5.201917, 0.100888,
              6.240936, 6.361378]
  },

  "training": {
    "optimizer": "Adam",
    "lr_initial": 0.0005,
    "weight_decay": 0.0001,
    "loss": "HuberLoss(delta=2.0)",
    "lr_scheduler": "ReduceLROnPlateau(factor=0.5, patience=8, min_lr=1e-5)",
    "batch_size": 32,
    "max_epochs": 150,
    "early_stopping_patience": 30,
    "epochs_run": 85,
    "gradient_clipping": "max_norm=1.0",
    "val_strategy": "temporal split (last 20% cycles per battery)",
    "best_val_loss_huber": 0.727444
  },

  "data_split": {
    "train_batteries": [
      "B0005","B0007","B0025","B0026","B0027","B0029","B0030","B0031",
      "B0032","B0033","B0036","B0038","B0040","B0042","B0043","B0044",
      "B0046","B0047","B0048"
    ],
    "test_batteries": ["B0006","B0018","B0028","B0034","B0039"],
    "n_train_windows": 944,
    "n_test_windows": 299
  },

  "performance": {
    "model": "Ensemble LSTM#16 + Ridge (alpha=0.05/0.95)",
    "MAE_test_pct": 1.0519,
    "RMSE_test_pct": 1.7525,
    "R2_test": 0.9486,
    "bias_test_pct": 0.2188,
    "y_pred_range": [69.78, 97.98],
    "y_test_range": [70.12, 98.67],
    "lstm_solo": {"MAE": 1.2953, "RMSE": 2.1105, "R2": 0.9255},
    "ridge_solo": {"MAE": 1.0582, "RMSE": 1.7537, "R2": 0.9486}
  },

  "baselines": {
    "ridge_inter_cycle": {"MAE": 3.507, "RMSE": 4.368, "R2": 0.707},
    "lstm_intra_cycle":  {"MAE": 4.5,   "RMSE": 5.8,   "R2": 0.40},
    "bilstm_run7":       {"MAE": 2.834, "RMSE": 3.565, "R2": 0.787}
  },

  "known_limitations": [
    "SoH ceiling ~93%: LSTM seul ne prédit pas SoH > 93% — corrigé par le Ridge dans l'ensemble (range [69.78, 97.98])",
    "Trained on NASA/CALCE protocol — performance on other protocols not guaranteed",
    "Small dataset (944 effective train samples) — larger BiLSTM(128) degraded performance",
    "soh_prev and soh_lin_extrap require BMS access to previous cycle SoH — always available in real deployments"
  ],

  "inference": {
    "script": "inference.py",
    "class": "SoHPredictor",
    "input_normalized": "predictor.predict(X)      # X shape (10,13) or (N,10,13)",
    "input_raw":        "predictor.predict_raw(X)   # applies scaler automatically",
    "cli": "python inference.py --input data.npy [--raw] [--output preds.npy]"
  }
}
